{
  "name": "hsk-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/generateStaticSeo.mjs",
    "preview": "vite preview",
    "seo:generate": "node scripts/generateStaticSeo.mjs",
    "seo:verify": "node scripts/verifyStaticSeo.mjs",
    "translate:hsk6": "node scripts/generateHsk6Translations.mjs",
    "translate:hsk6:ru": "node scripts/generateHsk6Translations.mjs --lang=ru",
    "translate:hsk6:validate": "node scripts/validateHsk6Translations.mjs",
    "audio:hsk": "node scripts/generateHskAudio.mjs",
    "audio:hsk1": "node scripts/generateHskAudio.mjs --levels=1",
    "audio:hsk6": "node scripts/generateHskAudio.mjs --levels=6 --kind=words",
    "hsk3:extract": "node scripts/extractHsk3VocabularyFromPdf.mjs",
    "hsk3:import": "node scripts/importHsk3Vocabulary.mjs",
    "hsk3:validate": "node scripts/importHsk3Vocabulary.mjs --validate",
    "hsk3:analyze-reuse": "node scripts/analyzeHsk3Reuse.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "hanzi-writer": "^3.7.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "pdfjs-dist": "^5.7.284"
  }
}
